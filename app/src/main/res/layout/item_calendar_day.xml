<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="2dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <FrameLayout
        android:id="@+id/layout_day_number_container"
        android:layout_width="34dp"
        android:layout_height="34dp">

        <View
            android:id="@+id/view_selection_circle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_background"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/tv_day_number"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="15"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Task deadline priority dot indicators container -->
    <LinearLayout
        android:id="@+id/layout_dot_container"
        android:layout_width="wrap_content"
        android:layout_height="6dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <View
            android:id="@+id/view_dot_high"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/priority_high"
            android:layout_marginHorizontal="1dp"
            android:visibility="gone"/>

        <View
            android:id="@+id/view_dot_medium"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/priority_medium"
            android:layout_marginHorizontal="1dp"
            android:visibility="gone"/>

        <View
            android:id="@+id/view_dot_low"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/priority_low"
            android:layout_marginHorizontal="1dp"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>
